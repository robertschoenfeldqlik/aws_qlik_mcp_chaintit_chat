# AWS Bedrock API Key (generate from Bedrock console > API keys)
AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key-here
AWS_DEFAULT_REGION=us-east-1

# Qlik Cloud (optional — pre-fills the plug icon form)
QLIK_TENANT_URL=https://your-tenant.us.qlikcloud.com
QLIK_OAUTH_CLIENT_ID=your-oauth-client-id

# App
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
CHAINLIT_PORT=8000
